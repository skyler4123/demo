<div class='w-1/2'>
  <%= render(Button::ClipboardComponent.new) do %>
    <input type='text'>
  <% end %>
</div>

<%= render(Dropdown::DropdownComponent.new(header: 'Test Dropdownnnnnnn')) do %>
  <li><%= link_to "LInk 1", '#' %></li>
  <li class="hover:text-red-500"><%= link_to "LInk 21111111111111111111111", '#' %></li>
  <li><%= link_to "LInk 3", '#' %></li>
  <li><%= link_to "LInk 4", '#' %></li>
<% end %>


<%= render(Table::TableComponent.new) do %>
  <%= render(Table::HeaderComponent.new) do %>
    <%= render(Table::HeadComponent.new(head_name: 'Email', type: 'email')) %>
    <%= render(Table::HeadComponent.new(head_name: 'Name', type: 'name')) %>
    <%= render(Table::HeadComponent.new(head_name: 'Birthday', type: 'birthday')) %>
    <%= render(Table::HeadComponent.new(head_name: 'Phone', type: 'phone')) %>
    <%= render(Table::HeadComponent.new(head_name: 'Balance', type: 'balance')) %>
    <%= render(Table::HeadComponent.new(head_name: 'Role', type: 'role')) %>
    <%= render(Table::HeadComponent.new(head_name: 'Confirm Code', type: 'confirm_code')) %>
    <%= render(Table::HeadComponent.new(head_name: 'Last Active At', type: 'last_active_at')) %>
  <% end %>
  <%= render(Table::BodyComponent.new) do %>
    <% @users.each do |user| %>
      <%= render(Table::RowComponent.new(id: user.id)) do %>
        <%= render(Table::CellComponent.new) do %>
          <%= render(Button::ClipboardComponent.new) do %>
            <div><%= user.email %></div>
          <% end %>
        <% end %>
        <%= render(Table::CellComponent.new(cell_value: user.name)) %>
        <%= render(Table::CellComponent.new(cell_value: user.birthday.iso8601)) %>
        <%= render(Table::CellComponent.new(cell_value: user.phone)) %>
        <%= render(Table::CellComponent.new(cell_value: user.balance)) %>
        <%= render(Table::CellComponent.new(cell_value: user.role)) %>
        <%= render(Table::CellComponent.new(cell_value: user.confirm_code)) %>
        <%= render(Table::CellComponent.new(cell_value: user.last_active_at.iso8601)) %>
      <% end %>
    <% end %>
  <% end %>
<% end %>




